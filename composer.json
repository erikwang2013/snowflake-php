{
    "name": "erikwang2013/snowflake-php",
    "description": "A distributed unique ID generator based on Twitter's Snowflake algorithm, compatible with Laravel, Webman, ThinkPHP, and Hyperf.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "snowflake",
        "unique-id",
        "distributed",
        "id-generator"
    ],
    "authors": [
        {
            "name": "erikwang2013"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5 || ^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Snowflake\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Snowflake\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Snowflake\\Adapters\\Laravel\\ServiceProvider"
            ],
            "aliases": {
                "Snowflake": "Snowflake\\Adapters\\Laravel\\Facade"
            }
        },
        "hyperf": {
            "config": "Snowflake\\Adapters\\Hyperf\\ConfigProvider"
        }
    },
    "suggest": {
        "laravel/framework": "For Laravel integration",
        "workerman/webman-framework": "For Webman integration",
        "topthink/framework": "For ThinkPHP 6+ integration",
        "hyperf/framework": "For Hyperf integration"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
